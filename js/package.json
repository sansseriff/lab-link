{
  "name": "lab-link",
  "version": "0.4.0",
  "type": "module",
  "description": "Browser runtime and adapters for server-authoritative lab link",
  "homepage": "https://sansseriff.github.io/lab-link/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sansseriff/lab-link.git",
    "directory": "js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "default": "./dist/core/index.js"
    },
    "./model": {
      "types": "./dist/model/index.d.ts",
      "default": "./dist/model/index.js"
    },
    "./auth": {
      "types": "./dist/auth/index.d.ts",
      "default": "./dist/auth/index.js"
    },
    "./svelte": {
      "types": "./dist/svelte/index.d.ts",
      "svelte": "./dist/svelte/index.js",
      "default": "./dist/svelte/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "default": "./dist/react/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "svelte-package -i src -o dist",
    "dev": "svelte-package -i src -o dist --watch",
    "test": "bun test"
  },
  "devDependencies": {
    "@sveltejs/package": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "svelte": "^5.55.0",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "svelte": ">=5"
  },
  "peerDependenciesOptional": {
    "react": true
  }
}
