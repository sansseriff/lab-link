{
  "name": "lab-sync",
  "version": "0.1.0",
  "type": "module",
  "description": "Generic server-authoritative sync library — browser client",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./svelte": {
      "types": "./dist/svelte/index.d.ts",
      "svelte": "./dist/svelte/index.js",
      "default": "./dist/svelte/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "default": "./dist/react/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "svelte-package -i src -o dist",
    "dev": "svelte-package -i src -o dist --watch",
    "test": "bun test"
  },
  "devDependencies": {
    "@sveltejs/package": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "svelte": "^5.55.0",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "svelte": ">=5"
  },
  "peerDependenciesOptional": {
    "react": true
  }
}
